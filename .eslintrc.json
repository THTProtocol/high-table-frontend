{
  "env": {
    "browser": true,
    "es2020": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "script"
  },
  "globals": {
    "firebase": "readonly",
    "kaspaSDK": "readonly",
    "Chess": "readonly",
    "BigInt": "readonly"
  },
  "rules": {
    "no-unused-vars": "off",
    "no-undef": "off",
    "no-console": "off",
    "no-prototype-builtins": "off",
    "no-redeclare": "warn",
    "no-constant-condition": "warn"
  },
  "ignorePatterns": [
    "firebase-app-compat.js",
    "firebase-database-compat.js",
    "chess.min.js",
    "kaspa_bg.wasm",
    "node_modules/",
    "functions/node_modules/",
    "htp-oracle-daemon/node_modules/"
  ]
}
