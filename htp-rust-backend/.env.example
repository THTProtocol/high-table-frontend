# HTP Rust Backend Configuration

# Kaspa network: testnet-12 or mainnet
KASPA_NETWORK=testnet-12

# Kaspa REST API base URL
KASPA_API_BASE=https://api-tn12.kaspa.org

# Kaspa RPC WebSocket URL (for future direct RPC integration)
KASPA_RPC_URL=wss://rpc-tn12.kaspa.org

# Server port
PORT=3000

# Log level
RUST_LOG=htp_backend=info,tower_http=info
