{
  "rules": {
    "escrows": {
      "$escrowId": {
        ".read": "auth != null || true",
        ".write": "auth != null || true",
        ".validate": "newData.hasChildren(['covenant_id', 'tx_hash']) && newData.child('covenant_id').val().length >= 64",
        "players": {
          "$playerAddress": {
            ".validate": "newData.hasChildren(['joined','ts'])"
          }
        }
      }
    },
    "results": {
      ".read": true,
      ".write": "auth != null"
    },
    ".write": "auth != null || root.child('allowPublic').val() === true",
    ".read": "auth != null || true"
  }
}
